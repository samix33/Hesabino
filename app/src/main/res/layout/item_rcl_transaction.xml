<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF"
    android:layoutDirection="rtl">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- آیکن دسته -->
        <TextView
            android:id="@+id/iconBg"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🛒"

            android:textSize="22sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@drawable/bg_transaction_icon_soft" />


        <!-- عنوان -->
        <TextView
            android:fontFamily="@font/vazirmatn_bold"
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="خرید از سوپرمارکت"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1F1F1F"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toTopOf="@id/iconBg"
            app:layout_constraintEnd_toStartOf="@id/iconBg"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- توضیح -->
        <TextView
            android:fontFamily="@font/vazirmatn_regular"
            android:id="@+id/tvNote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="مواد غذایی"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="@id/tvTitle"/>

        <!-- تاریخ -->
        <TextView
            android:id="@+id/tvDate"
            android:fontFamily="@font/vazirmatn_regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="۲۵ فروردین"
            android:textSize="13sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvNote"
            app:layout_constraintEnd_toEndOf="@id/tvNote"/>

        <!-- مبلغ -->
        <TextView
            android:fontFamily="@font/vazirmatn_semibold"
            android:id="@+id/tvAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="-۳۵۰,۰۰۰ تومان"
            android:textColor="#DC2626"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/tvDate"
            app:layout_constraintEnd_toEndOf="@+id/tvTitle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.277" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>